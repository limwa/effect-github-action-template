{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "tsBuildInfoFile": "./out-tsc/spec/tsconfig.spec.tsbuildinfo",
    
    "types": ["vitest", "vitest/importMeta", "node"],
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "vitest.config.ts",
    "tests/**/*.spec.ts",
    "tests/**/*.d.ts",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}