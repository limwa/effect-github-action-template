{
  // Visit https://aka.ms/tsconfig to read more about this file
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "./out-tsc/lib",
    "tsBuildInfoFile": "./out-tsc/lib/tsconfig.lib.tsbuildinfo",
    
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
  },
  "include": ["src/**/*"]
}
